{
  "name": "Metallic Robot",
  "description": "Classic sci-fi villain — comb filter metallic ring with echo and presence boost",
  "chain": [
    {"type": "CombFilter", "enabled": true, "params": {"delay_seconds": 0.015, "decay": 0.6}},
    {"type": "HighpassFilter", "enabled": true, "params": {"cutoff_frequency_hz": 100}},
    {"type": "PeakFilter", "enabled": true, "params": {"cutoff_frequency_hz": 3000, "gain_db": 6.0, "q": 1.0}},
    {"type": "Delay", "enabled": true, "params": {"delay_seconds": 0.08, "feedback": 0.3, "mix": 0.25}},
    {"type": "Compressor", "enabled": true, "params": {"threshold_db": -20.0, "ratio": 4.0}},
    {"type": "Gain", "enabled": true, "params": {"gain_db": 0.0}}
  ]
}
