    {"type": "LowpassFilter", "enabled": true, "params": {"cutoff_frequency_hz": 6000, "rolloff_db_per_oct": 12}},
    {"type": "PeakFilter", "enabled": true, "params": {"cutoff_frequency_hz": 430, "gain_db": 8.0, "q": 1.2}},
    {"type": "PeakFilter", "enabled": true, "params": {"cutoff_frequency_hz": 2700, "gain_db": 4.0, "q": 1.0}},
    {"type": "Compressor", "enabled": true, "params": {"threshold_db": -18.0, "ratio": 3.0}},
    {"type": "Gain", "enabled": true, "params": {"gain_db": 0.0}}
  ]
}
