{
  "name": "Dalek",
  "description": "Aggressive metallic robot with hard distortion — Doctor Who villain style",
  "chain": [
    {"type": "CombFilter", "enabled": true, "params": {"delay_seconds": 0.012, "decay": 0.6}},
    {"type": "Distortion", "enabled": true, "params": {"drive_db": 10.0}},
    {"type": "HighpassFilter", "enabled": true, "params": {"cutoff_frequency_hz": 100}},
    {"type": "PeakFilter", "enabled": true, "params": {"cutoff_frequency_hz": 3000, "gain_db": 8.0, "q": 1.0}},
    {"type": "Compressor", "enabled": true, "params": {"threshold_db": -20.0, "ratio": 6.0}},
    {"type": "Gain", "enabled": true, "params": {"gain_db": 0.0}}
  ]
}
