{
  "name": "Vintage",
  "description": "Warm vintage character — soft saturation, telephone bandpass EQ, gentle pitch drift, and subtle room reverb",
  "chain": [
    {"type": "Limiter", "enabled": true, "params": {"threshold_db": -1.0, "release_ms": 100.0}},
    {"type": "Clipping", "enabled": true, "params": {"threshold_db": -8.5}},
    {"type": "Distortion", "enabled": true, "params": {"drive_db": 8.0}},
    {"type": "HighpassFilter", "enabled": true, "params": {"cutoff_frequency_hz": 700.0, "rolloff_db_per_oct": 48.0}},
    {"type": "LowpassFilter", "enabled": true, "params": {"cutoff_frequency_hz": 4000.0, "rolloff_db_per_oct": 12.0}},
    {
      "type": "ParametricEQ",
      "enabled": true,
      "params": {},
      "bands": [
        {"freq": 200.0, "gain": -14.254, "q": 1.5},
        {"freq": 250.0, "gain": -7.243, "q": 2.0},
        {"freq": 315.0, "gain": -2.245, "q": 2.0},
        {"freq": 400.0, "gain": -0.414, "q": 2.0},
        {"freq": 3150.0, "gain": -0.874, "q": 1.5},
        {"freq": 4000.0, "gain": -3.992, "q": 1.5},
        {"freq": 5000.0, "gain": -9.993, "q": 1.5}
      ]
    },
    {"type": "PitchShift", "enabled": true, "params": {"semitones": 0.5}},
    {"type": "Reverb", "enabled": true, "params": {"room_size": 0.2, "damping": 0.5, "wet_level": 0.08, "dry_level": 0.89, "width": 1.0, "freeze_mode": 0.0}}
  ]
